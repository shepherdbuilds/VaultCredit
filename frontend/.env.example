# Contract address after deploying with: npm run deploy:sepolia (from repo root)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Sepolia RPC URL for fhevmjs instance initialization
# Any standard Sepolia RPC works (Infura, Alchemy, Ankr public endpoint, etc.)
VITE_SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# Zama fhEVM coprocessor endpoint (required in fhevmjs 0.5.x coprocessor mode)
VITE_COPROCESSOR_URL=https://coprocessor.sepolia.zama.ai

# Zama gateway URL for re-encryption / threshold comparison requests
VITE_GATEWAY_URL=https://gateway.sepolia.zama.ai
